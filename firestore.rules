rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role in ['teacher', 'admin'];
    }

    function isStudent(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isAdmin() || isStudent(uid);
      allow write: if false;
    }

    match /students/{studentId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.studentId == studentId);
      allow write: if false;
    }

    match /practiceSessions/{sessionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentUid == request.auth.uid);
      allow write: if false;
    }

    match /inventory/{studentId}/items/{itemId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.studentId == studentId);
      allow write: if false;
    }

    match /marketItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /statistics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
